# ================================================
# ProjectHub — Frontend Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git
# ================================================

# ─── Backend API URL ─────────────────────────────────────────────────────────
# Dev:  leave empty so Vite's proxy handles /api → http://localhost:3001
# Prod: set to your deployed backend URL e.g. https://api.projecthub.app
VITE_API_URL=
