# ================================================
# ProjectHub — Backend Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git
# ================================================

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── PostgreSQL (Neon) ───────────────────────────────────────────────────────
# Get this from: https://console.neon.tech → Connection Details → .env tab
DATABASE_URL=postgresql://user:password@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Must be at least 32 characters. Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-me-to-something-random-at-least-32-chars
JWT_EXPIRE=7d

# ─── Gmail SMTP (for OTP emails) ─────────────────────────────────────────────
# Generate App Password: Google Account → Security → 2-Step Verification → App Passwords
EMAIL_USER=your_gmail@gmail.com
EMAIL_APP_PASSWORD=your_16_char_gmail_app_password
EMAIL_FROM="ProjectHub <noreply@projecthub.app>"

# ─── CORS ────────────────────────────────────────────────────────────────────
# Set to your frontend URL. Dev: http://localhost:8080  Prod: https://your-app.vercel.app
FRONTEND_URL=http://localhost:8080
